generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id              String   @id @default(cuid())
  shop            String   @unique
  myshopifyDomain String?
  currency        String   @default("USD")
  timezone        String   @default("America/New_York")
  installedAt     DateTime @default(now())
  uninstalledAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  subscriptionStatus String  @default("trial")
  planId             String?
  trialEndsAt        DateTime?
  products        Product[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  notificationSettings NotificationSetting[]
}

model Product {
  id              String   @id
  storeId         String
  title           String
  vendor          String?
  productType     String?
  status          String   @default("active")
  sku             String?
  barcode         String?
  inventoryQty    Int      @default(0)
  inventoryCost   Float?
  price           Float?
  compareAtPrice  Float?
  imageUrl        String?
  shopifyInventoryItemId String?
  shopifyLocationId      String?
  isTracking      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  leadTimeDays    Int      @default(14)
  safetyStock     Int      @default(0)
  reorderPoint    Int?
  reorderQty      Int?
  salesVelocity   Float    @default(0)
  daysOfSupply    Float    @default(0)
  lastSoldAt      DateTime?
  totalSold30     Int      @default(0)
  totalSold90     Int      @default(0)
  revenueAtRisk   Float    @default(0)
  store           Store    @relation(fields: [storeId], references: [id])
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  alerts          StockAlert[]
  purchaseOrderLines PurchaseOrderLine[]

  @@unique([storeId, sku])
  @@index([storeId, status])
}

model Supplier {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  email       String?
  phone       String?
  leadTimeDays Int     @default(14)
  moq         Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id])
  products    Product[]
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id             String   @id @default(cuid())
  storeId        String
  supplierId     String
  status         String   @default("draft")
  orderNumber    String
  expectedDate   DateTime?
  notes          String?
  totalCost      Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sentAt         DateTime?
  receivedAt     DateTime?
  cancelledAt    DateTime?
  store          Store    @relation(fields: [storeId], references: [id])
  supplier       Supplier @relation(fields: [supplierId], references: [id])
  lines          PurchaseOrderLine[]

  @@unique([storeId, orderNumber])
  @@index([storeId, status])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  titleSnapshot   String
  skuSnapshot     String?
  quantity        Int
  unitCost        Float
  lineTotal       Float
  createdAt       DateTime      @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model StockAlert {
  id         String   @id @default(cuid())
  storeId    String
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  type       String
  message    String
  severity   String
  isRead     Boolean  @default(false)
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  storeId             String   @unique
  emailEnabled        Boolean  @default(true)
  emailRecipients     String?
  slackEnabled        Boolean  @default(false)
  slackWebhookUrl     String?
  dailyDigestEnabled  Boolean  @default(true)
  dailyDigestTime     String   @default("08:00")
  alertTypes          String   @default("low_stock,out_of_stock,dead_stock")
  store               Store    @relation(fields: [storeId], references: [id])
}

model JobLog {
  id          String   @id @default(cuid())
  storeId     String?
  jobType     String
  status      String
  message     String?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  error       String?
}

# === STOCKBRIDGE ENVIRONMENT VARIABLES ===
# Copy to .env and fill in your values

SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders
SHOPIFY_APP_URL=https://stockbridge-ua7x.onrender.com
SHOP_CUSTOM_DOMAIN=
SESSION_SECRET=generate_a_random_64_char_secret
DATABASE_URL=postgresql://user:password@host:5432/stockbridge_db
REDIS_URL=redis://default:password@host:port
SENDGRID_API_KEY=
NOTIFICATION_FROM_EMAIL=alerts@stockbridge.app
